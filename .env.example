# TaxOps — variables de entorno
# Copia este archivo como .env y llena los valores reales
# NUNCA hagas commit del .env real

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=taxops
POSTGRES_PASSWORD=CAMBIA_ESTA_CLAVE
POSTGRES_DB=taxops

# SQLAlchemy DSN (construida automáticamente en docker-compose)
DATABASE_URL=postgresql://taxops:CAMBIA_ESTA_CLAVE@db:5432/taxops

# ── Groq (chatbot) ────────────────────────────────────────────
GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXXXXXXXXXX

# ── Entorno ───────────────────────────────────────────────────
# development | staging | production
TAXOPS_ENV=development

# ── Organización activa (multi-tenant futuro) ─────────────────
# UUID de la org activa en Streamlit (sesión single-tenant actual)
TAXOPS_ORG_ID=00000000-0000-0000-0000-000000000000
